# Assistente (Neurosint) — variáveis de ambiente.
# Copie para .env (gitignored) e preencha. Em produção (Cloud Run) estes valores são
# injetados via Secret Manager (--set-secrets) — ver tools/deploy-cloud-run.example.sh.
# ⚠️ NUNCA commite o .env preenchido.

# === SEGREDOS (chaves de API) ===============================================
# Anthropic — conselho (claude-sonnet) + haiku (PDF/resumo)
ANTHROPIC_API_KEY=

# OpenAI — Whisper (transcrição de áudio) + visão (descrição de imagem)
OPENAI_API_KEY=

# ElevenLabs — TTS (voz)
ELEVENLABS_API_KEY=

# Supabase — service role key do seu projeto
SUPABASE_SERVICE_KEY=

# Evolution API — apikey da sua instância de WhatsApp
EVOLUTION_API_KEY=

# OpenEvidence — token do tool de evidência científica (opcional)
OPENEVIDENCE_API_KEY=

# Segredo compartilhado que protege os endpoints /cron/* (recomendado)
CRON_SECRET=

# === IDENTIFICADORES (NÃO são segredos, mas são dados do seu caso) ==========
# Preencha com os SEUS valores (ficam só no .env, nunca no repo).
PATIENT_ID=
GROUP_JID=
ALERT_NUMBER=
CAREGIVER_JID=
EVOLUTION_BASE=
EVOLUTION_INSTANCE=
SUPABASE_URL=
# Bucket de áudio no Storage do Supabase (opcional; default: audio-files)
SUPABASE_AUDIO_BUCKET=audio-files
ELEVENLABS_VOICE_ID=

# Nomes que o assistente usa nas falas (opcional; default em config.example.js)
ASSISTANT_NAME=Neurosint
PATIENT_NAME=
CAREGIVER_NAME=
MANAGER_NAME=

# === Secret Manager (opcional, p/ deploy) ===================================
# Projeto GCP onde vivem os segredos e prefixo dos nomes (ex.: "neurosint--").
GSM_PROJECT=
GSM_PREFIX=

# === Operação ===============================================================
# Ligar node-cron interno (true) em vez de Cloud Scheduler (default false em prod)
ENABLE_INTERNAL_CRON=false
# Porta (Cloud Run injeta PORT=8080)
PORT=8080
# Fuso horário dos agendamentos
TZ=America/Sao_Paulo
# Logs verbosos de depuração (defina qualquer valor para ligar; vazio = desligado)
DEBUG=
