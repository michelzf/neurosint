# =====================================================================
# Neurosint — Edge Functions · variáveis de ambiente (copie por preset)
# =====================================================================
# Toggles ORTOGONAIS: cada capacidade tem seu provider, então o destino de
# cada dado é EXPLÍCITO. Há 3 presets abaixo — copie um para .env.local ou
# .env.server (ambos gitignored) e ajuste.
#
# SUPABASE_URL / SUPABASE_ANON_KEY / SUPABASE_SERVICE_ROLE_KEY são INJETADOS
# automaticamente pelo runtime do Supabase (local e hospedado). Não precisa
# defini-los aqui para rodar as functions — só para scripts/curl externos.
# =====================================================================

# --------- PRESET A · 100% LOCAL, SEM CHAVE, SEM REDE (furo vertical/CI) -----
# Tudo em echo: nenhuma IA real, nada sai da máquina. Bom para testar o fluxo.
NEUROSINT_TARGET=local
OFFLINE_STRICT=true
LLM_PROVIDER=echo
STT_PROVIDER=echo
VISION_PROVIDER=echo
TTS_PROVIDER=none
EVIDENCE_PROVIDER=none

# --------- PRESET B · 100% LOCAL, PRIVACIDADE TOTAL (Ollama + whisper) -------
# Descomente este bloco e comente o Preset A. Requer Ollama + faster-whisper
# rodando no host. OFFLINE_STRICT=true recusa subir se algo não for local.
# NEUROSINT_TARGET=local
# OFFLINE_STRICT=true
# LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://host.docker.internal:11434/v1
# OLLAMA_COUNCIL_MODEL=qwen2.5:32b
# OLLAMA_HAIKU_MODEL=llama3.1:8b
# STT_PROVIDER=faster_whisper
# STT_BASE_URL=http://host.docker.internal:9000
# STT_MODEL=large-v3
# VISION_PROVIDER=ollama_vision
# TTS_PROVIDER=none          # ou piper — descomente também a linha abaixo:
# PIPER_BASE_URL=http://host.docker.internal:10200
# EVIDENCE_PROVIDER=none     # tool-use local é incerto; mantenha none

# --------- PRESET C · SERVIDOR (nuvem, melhor raciocínio) --------------------
# Descomente e preencha as chaves. PHI vai a terceiros — exige consentimento.
# NEUROSINT_TARGET=server
# OFFLINE_STRICT=false
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# COUNCIL_MODEL=claude-sonnet-4-6
# HAIKU_MODEL=claude-haiku-4-5-20251001
# STT_PROVIDER=openai
# VISION_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# TTS_PROVIDER=none          # ou elevenlabs — descomente também as duas linhas abaixo:
# ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID=
# EVIDENCE_PROVIDER=openevidence   # descomente também a linha abaixo:
# OPENEVIDENCE_API_KEY=
# PHI_PSEUDONYMIZE=true      # troca o nome do paciente por token antes do LLM

# --------- Comuns -----------------------------------------------------------
ASSISTANT_NAME=Neurosint
COUNCIL_MAX_TOKENS=1500
COUNCIL_TEMPERATURE=0.4
RECENT_MESSAGES_LIMIT=50
ANTHROPIC_VERSION=2023-06-01
WHISPER_MODEL=whisper-1
VISION_MODEL=gpt-4.1-mini
ELEVENLABS_MODEL=eleven_flash_v2_5
OPENEVIDENCE_MODEL=oe-v2
